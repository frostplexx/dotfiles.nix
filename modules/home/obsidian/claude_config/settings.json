{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(obsidian *)",
      "Bash(pdftotext *)",
      "Read( **/*.md)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": []
  },
  "env": {},
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  }
}